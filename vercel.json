{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_INSTANT_APP_ID": "@next_public_instant_app_id",
    "INSTANT_ADMIN_TOKEN": "@instant_admin_token"
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/:path*"
    }
  ]
}
