# HoneyStore365 - Environment Variables

# ==========================================
# InstantDB Configuration (Required)
# ==========================================

# Your InstantDB App ID
# Found at: https://instantdb.com/dash → Your App → Settings
NEXT_PUBLIC_INSTANT_APP_ID=68720b42-a379-4ba1-939e-f73b2c877b77

# Your InstantDB Admin Token (Server-side only)
# Found at: https://instantdb.com/dash → Your App → Settings → Admin Token
INSTANT_ADMIN_TOKEN=0d0b1fe1-a270-4779-ba17-4e30eb476b54

# ==========================================
# Tunisian Store Settings
# ==========================================

NEXT_PUBLIC_STORE_NAME="HoneyStore365"
NEXT_PUBLIC_STORE_CURRENCY="TND"
NEXT_PUBLIC_DELIVERY_FEE=7

# Admin email for notifications (optional)
ADMIN_EMAIL=votre-email@example.com

# ==========================================
# Optional: For future integrations
# ==========================================

# If you want to add email notifications later
# RESEND_API_KEY=re_...

# If you want to add SMS notifications
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
